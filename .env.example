# Copy this file to .env.local for local development, and set the same
# variables in Railway (Project -> Variables) for production.

# Your Resend API key (https://resend.com -> API Keys). Starts with "re_".
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where referral notifications get sent. You can list several, comma-separated.
REFERRAL_NOTIFY_EMAIL=you@usenash.com

# The "from" address. Until you verify your own domain in Resend, leave this
# as the default below (Resend's test sender can only deliver to your own
# Resend account email). Once your domain is verified, switch to something
# like: Nash Referrals <referrals@usenash.com>
REFERRAL_FROM_EMAIL=Nash Referrals <onboarding@resend.dev>
